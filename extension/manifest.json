{
  "manifest_version": 3,
  "name": "GDE - Google Meet Summarizer",
  "version": "1.0.0",
  "description": "Auto-summarize Google Meet sessions and extract action items using AI",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "messaging"
  ],
  "host_permissions": [
    "https://meet.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "GDE Meeting Summarizer"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["content.js"],
      "matches": ["https://meet.google.com/*"]
    }
  ]
}
